{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ship Studio",
  "version": "0.2.9",
  "identifier": "com.memberstack.shipstudio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ship Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https:; font-src 'self' data:; connect-src 'self' http://localhost:* ws://localhost:* wss://localhost:* https://*.github.com https://*.vercel.com https://api.anthropic.com; frame-src http://localhost:*;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/ShipStudio/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "fonts/*": "fonts/"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ship-studio/releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0ODczM0E5OUM4REE1NjMKUldSanBZMmNxVE9IZFBUeENHY3NPckZJcXBGT1Iwc2pZR1JrTXlNNEUwdFFPbVd6bCt6OWZjTm0K"
    }
  }
}
