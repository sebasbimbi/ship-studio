{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ship Studio",
  "version": "0.13.1",
  "identifier": "com.memberstack.shipstudio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/ShipStudio/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "fonts/*": "fonts/",
      "resources/scrcpy-server.jar": "scrcpy-server.jar"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ship-studio/releases/releases/latest/download/latest-{{target}}.json",
        "https://github.com/ship-studio/releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwOERENTAzOURDNjlFNkYKUldSdm5zYWRBOVdOa0VQQ09QckxabTA3ejVOSHBlSUs3d1I2NG02TmkzOVBmVUZ5OUp3L3QwbUkK"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "shipstudio"
        ]
      }
    }
  }
}